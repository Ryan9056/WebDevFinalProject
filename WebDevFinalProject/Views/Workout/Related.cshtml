@model List<WebDevFinalProject.Models.Exercise>

@{
    ViewData["Title"] = "Related Exercises";
}

<h1>Related Exercises</h1>
<p class="text-muted">
    Workout: <strong>@ViewBag.WorkoutName</strong> |
    Category: <strong>@ViewBag.WorkoutCategory</strong>
</p>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        No related exercises were found for this workout category.
    </div>
}
else
{
    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Duration (min)</th>
                <th>Difficulty</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var exercise in Model)
            {
                <tr>
                    <td>@exercise.Name</td>
                    <td>@exercise.Category</td>
                    <td>@exercise.Duration</td>
                    <td>@exercise.Difficulty</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary"
                           asp-controller="Exercise"
                           asp-action="Details"
                           asp-route-id="@exercise.Id">
                            Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a class="btn btn-secondary mt-3" asp-controller="Workout" asp-action="Index">Back to Workouts</a>