@model List<WebDevFinalProject.Models.Workout>

@{
    ViewData["Title"] = "Workouts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Workouts</h1>
    <p class="text-muted">Total workouts: @Model.Count</p>
    <a asp-action="Add" class="btn btn-dark">Add Workout</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No workouts have been added yet.
    </div>
}
else
{
    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Workout Category</th>
                <th>Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var workout in Model)
            {
                <tr>
                    <td>@workout.Name</td>
                    <td>@workout.WorkoutCategory</td>
                    <td>@workout.Date.ToShortDateString()</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary"
                           asp-controller="Workout"
                           asp-action="Details"
                           asp-route-id="@workout.Id">
                            Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}