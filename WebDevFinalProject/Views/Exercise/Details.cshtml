@model WebDevFinalProject.Models.Exercise

@{
    ViewData["Title"] = "Exercise Details";
}

<div class="card shadow-sm border-0 p-4">
    <h1 class="mb-3">Exercise Details</h1>

    <h3>@Model.Name</h3>
    <p><strong>Category:</strong> @Model.Category</p>
    <p><strong>Duration:</strong> @Model.Duration minutes</p>
    <p><strong>Difficulty:</strong> @Model.Difficulty</p>

    <a class="btn btn-secondary mt-3" asp-controller="Exercise" asp-action="Index">Back to Exercises</a>
</div>