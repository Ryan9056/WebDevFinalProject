@model List<WebDevFinalProject.Models.Exercise>

@{
    ViewData["Title"] = "Exercises";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Exercises</h1>
    <p class="text-muted">Total exercises: @Model.Count</p>
    <a asp-action="Add" class="btn btn-dark">Add Exercise</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No exercises have been added yet.
    </div>
}
else
{
    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Duration (min)</th>
                <th>Difficulty</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var exercise in Model)
            {
                <tr>
                    <td>@exercise.Name</td>
                    <td>@exercise.Category</td>
                    <td>@exercise.Duration</td>
                    <td>@exercise.Difficulty</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary"
                           asp-controller="Exercise"
                           asp-action="Details"
                           asp-route-id="@exercise.Id">
                            Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}